rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read and write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null;
      allow create: if request.auth != null;
    }
    
    // Chat rules - simplified for all users
    match /chats/{chatId} {
      allow read, write: if request.auth != null;
      allow create: if request.auth != null;
      
      match /messages/{messageId} {
        allow read, create: if request.auth != null;
        allow write, delete: if request.auth != null;
      }
      
      match /typing/{userId} {
        allow read, write, delete: if request.auth != null;
      }
    }
    
    // Members Collection Rules
    match /members/{memberId} {
      allow read, write, create: if request.auth != null;
      allow delete: if request.auth != null && 
        request.auth.token.email == 'admin@army.com';
    }
    
    // User Highlights Collection Rules
    match /user_highlights/{highlightId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow write, delete: if request.auth != null && 
        (request.auth.uid == resource.data.userId || 
         request.auth.token.email == 'admin@army.com');
    }
  }
}

// Firebase Storage Rules
service firebase.storage {
  match /b/{bucket}/o {
    // Profile images - users can only upload their own
    match /profile_images/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Chat images
    match /chat_images/{chatId}/{imageId} {
      allow read, write: if request.auth != null && 
        request.auth.uid in chatId.split('_');
    }
  }
}
